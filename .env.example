# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Supabase (get from: https://supabase.com/dashboard/project/<your-project>/settings/api)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_<your-key>
SUPABASE_PROJECT_ID=<project-ref>

# Vite build-time injected (same values — prefixed for client-side access)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<your-key>
VITE_SUPABASE_PROJECT_ID=<project-ref>
